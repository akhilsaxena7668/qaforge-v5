# QAForge Gemini — Example Environment File
# Rename this to .env and add your API keys

GEMINI_API_KEY_1=AIzaSy_your_primary_key_here
GEMINI_API_KEY_2=AIzaSy_optional_fallback_key_2
GEMINI_API_KEY_3=AIzaSy_optional_fallback_key_3
GEMINI_API_KEY_4=AIzaSy_optional_fallback_key_4

DEFAULT_MODEL=flash
MAX_TESTS=25
